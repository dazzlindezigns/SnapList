{
  "rewrites": [
    { "source": "/api/generate", "destination": "/api/generate" },
    { "source": "/api/mockup", "destination": "/api/mockup" },
    { "source": "/api/webhook", "destination": "/api/webhook" },
    { "source": "/((?!api/|.*\\.html$|.*\\.png$|.*\\.svg$|.*\\.ico$|.*\\.json$|.*\\.js$|.*\\.css$|.*\\.pdf$).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/mockup.js": {
      "maxDuration": 300
    },
    "api/generate.js": {
      "maxDuration": 30
    },
    "api/webhook.js": {
      "maxDuration": 30
    }
  }
}
